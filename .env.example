# 애플리케이션 환경
NODE_ENV=development

# Vercel 호스팅 (Vercel에서 자동으로 설정됨)
# VERCEL_URL=

# 애플리케이션 URL (브라우저에서 접근 가능한 URL)
# 개발 환경: http://localhost:3000
# 프로덕션 환경: https://your-domain.com
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Notion API 연동 (서버 전용, NEXT_PUBLIC 접두사 사용 금지)
# Notion Integration 생성: https://www.notion.so/my-integrations
# NOTION_API_KEY=secret_xxx
# 견적서 데이터베이스 ID (Notion 데이터베이스 URL에서 추출)
# NOTION_INVOICE_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude Code Hook - Slack 알림 설정
# Slack Incoming Webhook URL을 설정하면 Claude Code 작업 중
# 권한 요청 및 작업 완료 알림을 Slack으로 받을 수 있습니다.
# 설정 방법: https://api.slack.com/apps -> Create New App -> Incoming Webhooks
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR_WEBHOOK_URL
