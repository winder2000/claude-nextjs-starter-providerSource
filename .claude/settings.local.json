{
  "permissions": {
    "allow": [
      "Read",
      "Bash",
      "WebFetch",
      "WebSearch",
      "mcp__ide",
      "mcp__shadcn",
      "mcp__playwright",
      "mcp__sequential-thinking",
      "mcp__shadcn",
      "mcp__context7",
      "Skill(code-review)",
      "Skill(run)",
      "PowerShell([System.Environment]::GetEnvironmentVariable\\(\"SLACK_WEBHOOK_URL\", \"User\"\\))",
      "PowerShell($val = [System.Environment]::GetEnvironmentVariable\\(\"SLACK_WEBHOOK_URL\", \"User\"\\); if \\($val\\) { \"SET: $val\" } else { \"NOT SET \\(User scope\\)\" }; $val2 = [System.Environment]::GetEnvironmentVariable\\(\"SLACK_WEBHOOK_URL\", \"Machine\"\\); if \\($val2\\) { \"SET \\(Machine\\): $val2\" } else { \"NOT SET \\(Machine scope\\)\" })",
      "PowerShell($env:CLAUDE_PROJECT_DIR = \"C:\\\\Study\\\\Claude_Code\\\\Inflearn\\\\claude-nextjs-starter-providerSource\"; & \"C:\\\\Study\\\\Claude_Code\\\\Inflearn\\\\claude-nextjs-starter-providerSource\\\\.claude\\\\hooks\\\\notification-hook.ps1\")"
    ],
    "deny": [],
    "ask": []
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": ["playwright"],
  "hooks": {
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/notification-hook.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stop-hook.sh"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/task-complete-hook.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash(npm run check-all)",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/task-complete-hook.sh"
          }
        ]
      }
    ]
  }
}
